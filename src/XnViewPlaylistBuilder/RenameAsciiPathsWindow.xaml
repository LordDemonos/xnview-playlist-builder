<Window x:Class="XnViewPlaylistBuilder.RenameAsciiPathsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Fix non-ASCII paths"
        Height="560"
        Width="820"
        MinHeight="420"
        MinWidth="640"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="{StaticResource Brush.Background}"
        Foreground="{StaticResource Brush.TextPrimary}">
    <Grid Margin="24" Background="{StaticResource Brush.Background}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Fix non-ASCII paths" Style="{StaticResource Text.Display}"/>
            <TextBlock x:Name="SummaryTextBlock"
                       Margin="0,4,0,0"
                       Style="{StaticResource Text.Subtitle}"
                       TextWrapping="Wrap"/>
            <CheckBox x:Name="ShowMissingCheckBox"
                      Margin="0,12,0,0"
                      Content="Show paths not found on disk"
                      Visibility="Collapsed"
                      Checked="ShowMissingCheckBox_Changed"
                      Unchecked="ShowMissingCheckBox_Changed"/>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource Panel.Card}">
            <DataGrid x:Name="OperationsDataGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      GridLinesVisibility="Horizontal"
                      Background="Transparent"
                      BorderThickness="0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Status"
                                        Binding="{Binding Status}"
                                        Width="132"/>
                    <DataGridTextColumn Header="Current path"
                                        Binding="{Binding SourcePath}"
                                        Width="*"/>
                    <DataGridTextColumn Header="New ASCII path"
                                        Binding="{Binding TargetPath}"
                                        Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button Content="Cancel"
                    Style="{StaticResource Button.Secondary}"
                    MinWidth="88"
                    Margin="0,0,8,0"
                    IsCancel="True"/>
            <Button x:Name="ApplyButton"
                    Content="Rename on disk"
                    Style="{StaticResource Button.Primary}"
                    MinWidth="120"
                    IsDefault="True"
                    Click="ApplyButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
