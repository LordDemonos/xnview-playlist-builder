<Window x:Class="XnViewPlaylistBuilder.ConfirmDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        SizeToContent="Height"
        Width="520"
        MinWidth="420"
        MaxWidth="640"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource Brush.Background}"
        Foreground="{StaticResource Brush.TextPrimary}">
    <Grid Margin="24" Background="{StaticResource Brush.Background}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="TitleTextBlock"
                   Grid.Row="0"
                   Style="{StaticResource Text.Display}"/>

        <Border Grid.Row="1"
                Style="{StaticResource Panel.Card}"
                Margin="0,16,0,0">
            <StackPanel>
                <TextBlock x:Name="MessageTextBlock"
                           TextWrapping="Wrap"/>
                <TextBlock x:Name="DetailTextBlock"
                           Margin="0,12,0,0"
                           TextWrapping="Wrap"
                           FontFamily="{StaticResource Font.Mono}"
                           FontSize="11"
                           Foreground="{StaticResource Brush.TextSecondary}"
                           Visibility="Collapsed"/>
                <CheckBox x:Name="OptionCheckBox"
                          Margin="0,16,0,0"
                          Visibility="Collapsed"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,20,0,0">
            <Button x:Name="CancelButton"
                    Content="No"
                    Style="{StaticResource Button.Secondary}"
                    MinWidth="88"
                    Margin="0,0,8,0"
                    IsCancel="True"
                    Click="CancelButton_Click"/>
            <Button x:Name="ConfirmButton"
                    Content="Yes"
                    Style="{StaticResource Button.Primary}"
                    MinWidth="88"
                    IsDefault="True"
                    Click="ConfirmButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
