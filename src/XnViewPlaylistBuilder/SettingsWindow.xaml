<Window x:Class="XnViewPlaylistBuilder.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Height="680"
        Width="580"
        MinHeight="560"
        MinWidth="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{StaticResource Brush.Background}"
        Foreground="{StaticResource Brush.TextPrimary}">
    <Grid Margin="24" Background="{StaticResource Brush.Background}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Settings" Style="{StaticResource Text.Display}"/>
            <TextBlock Margin="0,4,0,0"
                       Style="{StaticResource Text.Subtitle}"
                       Text="Path policy, XnView MP, image types, and scan defaults."/>
        </StackPanel>

        <StackPanel Grid.Row="1">
            <TextBlock Text="Paths" Style="{StaticResource Text.GroupTitle}"/>
            <StackPanel Margin="0,0,0,20">
                <TextBlock Text="Save path policy" Style="{StaticResource Text.Label}" Margin="0,0,0,6"/>
                <ComboBox x:Name="PathPolicyComboBox"
                          DisplayMemberPath="Label"
                          SelectedValuePath="Policy"
                          Margin="0,0,0,8"/>
                <TextBlock x:Name="RelativePolicyWarningTextBlock"
                           Foreground="{StaticResource Brush.Accent}"
                           TextWrapping="Wrap"
                           Visibility="Collapsed"
                           Text="Relative-to-.sld paths are experimental. Test slideshow playback in XnView MP after moving files."/>
                <CheckBox x:Name="UseXnViewRelativePathsCheckBox"
                          Margin="0,12,0,0"
                          Content="Use XnView-style relative paths for non-ASCII entries (fallback only)"/>
                <TextBlock Margin="0,6,0,0"
                           Style="{StaticResource Text.Subtitle}"
                           TextWrapping="Wrap"
                           Text="Leave unchecked to keep absolute paths. Use Fix non-ASCII paths in the playlist panel for a permanent rename instead."/>
            </StackPanel>

            <TextBlock Text="XnView MP" Style="{StaticResource Text.GroupTitle}"/>
            <StackPanel Margin="0,0,0,20">
                <TextBlock Text="Executable path" Style="{StaticResource Text.Label}" Margin="0,0,0,6"/>
                <DockPanel Margin="0,0,0,8">
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <Button x:Name="DetectXnViewButton"
                                Content="Auto-detect"
                                Style="{StaticResource Button.Secondary}"
                                MinWidth="96"
                                Margin="8,0,0,0"
                                Click="DetectXnViewButton_Click"/>
                        <Button x:Name="BrowseXnViewButton"
                                Content="Browse…"
                                Style="{StaticResource Button.Secondary}"
                                MinWidth="88"
                                Margin="8,0,0,0"
                                Click="BrowseXnViewButton_Click"/>
                    </StackPanel>
                    <TextBox x:Name="XnViewPathTextBox"/>
                </DockPanel>
                <TextBlock Style="{StaticResource Text.Subtitle}"
                           Text="Used by Play in XnView (xnviewmp.exe -slide &quot;playlist.sld&quot;)."/>
            </StackPanel>

            <TextBlock Text="Scanning" Style="{StaticResource Text.GroupTitle}"/>
            <StackPanel Margin="0,0,0,8">
                <TextBlock Text="Image extensions" Style="{StaticResource Text.Label}" Margin="0,0,0,6"/>
                <TextBox x:Name="ExtensionsTextBox"
                         AcceptsReturn="False"
                         ToolTip="Comma-separated, include leading dot (e.g. .jpg, .png)"/>
                <TextBlock Margin="0,6,0,0"
                           Style="{StaticResource Text.Subtitle}"
                           Text="Only files matching these extensions are included when scanning folders."/>
                <CheckBox x:Name="DefaultIncludeSubfoldersCheckBox"
                          Margin="0,16,0,0"
                          Content="Include subfolders by default for new folders"/>
                <TextBlock Margin="0,6,0,0"
                           Style="{StaticResource Text.Subtitle}"
                           Text="Applies when you add folders. Each folder can still be toggled in the list below the playlist."/>
                <CheckBox x:Name="AllowDuplicatesCheckBox"
                          Margin="0,16,0,0"
                          Content="Allow duplicate files and folders"/>
                <TextBlock Margin="0,6,0,0"
                           Style="{StaticResource Text.Subtitle}"
                           TextWrapping="Wrap"
                           Text="When enabled, the same path can appear multiple times in the playlist — useful with Random order to show certain images more often. Duplicate scan folders are also allowed."/>
                <CheckBox x:Name="WriteActionLogsCheckBox"
                          Margin="0,16,0,0"
                          Content="Write detailed action logs (removals, fix names) to logs subfolders"/>
                <TextBlock Margin="0,6,0,0"
                           Style="{StaticResource Text.Subtitle}"
                           TextWrapping="Wrap"
                           Text="Keeps separate log files per action under AppData\XnViewPlaylistBuilder\logs instead of mixing everything into the daily app log."/>
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom">
            <Button Content="Cancel"
                    Style="{StaticResource Button.Secondary}"
                    MinWidth="88"
                    Margin="0,0,8,0"
                    IsCancel="True"/>
            <Button Content="Save"
                    Style="{StaticResource Button.Primary}"
                    MinWidth="88"
                    IsDefault="True"
                    Click="SaveButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
