<Window x:Class="XnViewPlaylistBuilder.RenameUndoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Undo renames from log"
        Height="760"
        Width="980"
        MinHeight="520"
        MinWidth="800"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="{StaticResource Brush.Background}"
        Foreground="{StaticResource Brush.TextPrimary}">
    <Grid Margin="24" Background="{StaticResource Brush.Background}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Undo renames from log"
                       Style="{StaticResource Text.Display}"/>
            <TextBlock Style="{StaticResource Text.Subtitle}"
                       Margin="0,4,0,0"
                       TextWrapping="Wrap"
                       Text="Set an anchor folder to undo leaf renames under corrected parents. Path substitutions fix stale log prefixes."/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Text="Log file"
                       VerticalAlignment="Center"
                       Margin="0,0,12,0"
                       Style="{StaticResource Text.Label}"/>
            <ComboBox x:Name="LogFileComboBox"
                      Grid.Column="1"
                      Style="{StaticResource ComboBox.Compact}"
                      MinHeight="36"
                      DisplayMemberPath="DisplayName"
                      SelectionChanged="LogFileComboBox_SelectionChanged"/>
            <Button Grid.Column="2"
                    Content="Browse…"
                    Style="{StaticResource Button.Secondary}"
                    Margin="8,0,0,0"
                    MinWidth="88"
                    Click="BrowseLogButton_Click"/>
        </Grid>

        <Grid Grid.Row="2" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Text="Anchor folder"
                       VerticalAlignment="Center"
                       Margin="0,0,12,0"
                       Style="{StaticResource Text.Label}"/>
            <TextBox x:Name="AnchorPathTextBox"
                     Grid.Column="1"
                     MinHeight="36"
                     VerticalContentAlignment="Center"
                     ToolTip="Corrected parent folder on disk, e.g. …\OF_Patreon. Leave empty for full-path undo."
                     TextChanged="AnchorOrFilter_Changed"/>
            <Button Grid.Column="2"
                    Content="Browse…"
                    Style="{StaticResource Button.Secondary}"
                    Margin="8,0,0,0"
                    MinWidth="88"
                    Click="BrowseAnchorButton_Click"/>
        </Grid>

        <Grid Grid.Row="3" Margin="0,0,0,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <DockPanel Grid.Row="0" Margin="0,0,0,6">
                <Button Content="Add substitution"
                        DockPanel.Dock="Right"
                        Style="{StaticResource Button.Secondary}"
                        MinWidth="120"
                        Padding="8,4"
                        FontSize="11"
                        Click="AddSubstitutionButton_Click"/>
                <TextBlock Text="Path substitutions (log segment → on disk now)"
                           Style="{StaticResource Text.Label}"
                           VerticalAlignment="Center"/>
            </DockPanel>
            <DataGrid x:Name="SubstitutionsDataGrid"
                      Grid.Row="1"
                      Height="88"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="True"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      Background="Transparent"
                      BorderThickness="1"
                      BorderBrush="{StaticResource Brush.Border}"
                      CellEditEnding="SubstitutionsDataGrid_CellEditEnding">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="In log"
                                        Binding="{Binding LogSegment, UpdateSourceTrigger=PropertyChanged}"
                                        Width="*"/>
                    <DataGridTextColumn Header="On disk now"
                                        Binding="{Binding DiskSegment, UpdateSourceTrigger=PropertyChanged}"
                                        Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    Margin="0,0,0,8">
            <CheckBox x:Name="FilterToAnchorChildrenCheckBox"
                      Content="Show only direct children of anchor"
                      IsChecked="True"
                      VerticalAlignment="Center"
                      Margin="0,0,16,0"
                      Checked="AnchorOrFilter_Changed"
                      Unchecked="AnchorOrFilter_Changed"/>
            <CheckBox x:Name="HideParentCorrectedCheckBox"
                      Content="Hide parent folder renames"
                      IsChecked="True"
                      VerticalAlignment="Center"
                      Checked="AnchorOrFilter_Changed"
                      Unchecked="AnchorOrFilter_Changed"/>
        </StackPanel>

        <Border Grid.Row="5" Style="{StaticResource Panel.Card}">
            <Grid>
                <DataGrid x:Name="OperationsDataGrid"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionMode="Extended"
                          HeadersVisibility="Column"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          GridLinesVisibility="Horizontal"
                          Background="Transparent"
                          BorderThickness="0"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling"
                          EnableRowVirtualization="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Line"
                                            Binding="{Binding LineNumber}"
                                            Width="52"/>
                        <DataGridTextColumn Header="Status"
                                            Binding="{Binding StatusLabel}"
                                            Width="140"/>
                        <DataGridTextColumn Header="Would undo on disk"
                                            Binding="{Binding ResolvedPathLabel}"
                                            Width="*"/>
                        <DataGridTextColumn Header="Original path"
                                            Binding="{Binding SourcePath}"
                                            Width="*"/>
                        <DataGridTextColumn Header="Renamed to"
                                            Binding="{Binding TargetPath}"
                                            Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
                <TextBlock x:Name="LoadingTextBlock"
                           Text="Loading log…"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource Brush.TextSecondary}"
                           Visibility="Collapsed"/>
            </Grid>
        </Border>

        <Grid Grid.Row="6" Margin="0,16,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <Button Content="Select all"
                        Style="{StaticResource Button.Secondary}"
                        MinWidth="88"
                        Margin="0,0,8,0"
                        Click="SelectAllButton_Click"/>
                <Button Content="Select ready"
                        Style="{StaticResource Button.Secondary}"
                        MinWidth="96"
                        Margin="0,0,8,0"
                        Click="SelectReadyButton_Click"/>
                <Button Content="Clear selection"
                        Style="{StaticResource Button.Secondary}"
                        MinWidth="112"
                        Click="ClearSelectionButton_Click"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock x:Name="SelectionSummaryTextBlock"
                           VerticalAlignment="Center"
                           Margin="0,0,16,0"
                           Foreground="{StaticResource Brush.TextSecondary}"/>
                <Button Content="Close"
                        Style="{StaticResource Button.Secondary}"
                        MinWidth="88"
                        Margin="0,0,8,0"
                        IsCancel="True"/>
                <Button x:Name="UndoButton"
                        Content="Undo selected"
                        Style="{StaticResource Button.Primary}"
                        MinWidth="120"
                        IsDefault="True"
                        Click="UndoButton_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
