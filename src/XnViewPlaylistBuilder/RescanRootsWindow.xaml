<Window x:Class="XnViewPlaylistBuilder.RescanRootsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Re-add scan folders"
        Height="560"
        Width="860"
        MinHeight="420"
        MinWidth="640"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="{StaticResource Brush.Background}"
        Foreground="{StaticResource Brush.TextPrimary}">
    <Grid Margin="24" Background="{StaticResource Brush.Background}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Re-add scan folders" Style="{StaticResource Text.Display}"/>
            <TextBlock x:Name="SummaryTextBlock"
                       Margin="0,4,0,0"
                       Style="{StaticResource Text.Subtitle}"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource Panel.Card}">
            <DataGrid x:Name="SuggestionsDataGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="False"
                      HeadersVisibility="Column"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      SelectionMode="Single"
                      GridLinesVisibility="Horizontal"
                      Background="Transparent"
                      BorderThickness="0">
                <DataGrid.Columns>
                    <DataGridCheckBoxColumn Header="Scan"
                                            Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                            Width="56"/>
                    <DataGridTextColumn Header="Folder"
                                        Binding="{Binding FolderPath}"
                                        IsReadOnly="True"
                                        Width="*"/>
                    <DataGridTextColumn Header="Removed files"
                                        Binding="{Binding RemovedFileCount, StringFormat=N0}"
                                        IsReadOnly="True"
                                        Width="112"/>
                    <DataGridTextColumn Header="Type"
                                        Binding="{Binding KindLabel}"
                                        IsReadOnly="True"
                                        Width="220"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Grid Grid.Row="2" Margin="0,16,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <Button x:Name="BrowseFolderButton"
                        Content="Browse for folder…"
                        Style="{StaticResource Button.Secondary}"
                        MinWidth="148"
                        Margin="0,0,8,0"
                        Click="BrowseFolderButton_Click"/>
                <Button x:Name="SelectSubjectFoldersButton"
                        Content="Select subject folders only"
                        Style="{StaticResource Button.Secondary}"
                        MinWidth="188"
                        Click="SelectSubjectFoldersButton_Click"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Skip"
                        Style="{StaticResource Button.Secondary}"
                        MinWidth="88"
                        Margin="0,0,8,0"
                        IsCancel="True"/>
                <Button x:Name="AddFoldersButton"
                        Content="Add to scan list"
                        Style="{StaticResource Button.Secondary}"
                        MinWidth="132"
                        Margin="0,0,8,0"
                        Click="AddFoldersButton_Click"/>
                <Button x:Name="AddAndScanButton"
                        Content="Add and scan"
                        Style="{StaticResource Button.Primary}"
                        MinWidth="120"
                        IsDefault="True"
                        Click="AddAndScanButton_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
