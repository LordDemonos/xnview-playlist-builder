<Window x:Class="XnViewPlaylistBuilder.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:XnViewPlaylistBuilder.Controls"
        Title="XnView Playlist Builder"
        Height="760"
        Width="1024"
        MinHeight="560"
        MinWidth="880"
        Icon="/Assets/app-icon.ico"
        Background="{StaticResource Brush.Background}"
        Foreground="{StaticResource Brush.TextPrimary}">
    <Grid Margin="24" Background="{StaticResource Brush.Background}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="XnView Playlist Builder"
                           Style="{StaticResource Text.Display}"
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="CurrentPlaylistSeparatorTextBlock"
                           Text="—"
                           Margin="12,0,12,0"
                           VerticalAlignment="Center"
                           FontSize="22"
                           Foreground="{StaticResource Brush.TextSecondary}"
                           Visibility="Collapsed"/>
                <TextBlock x:Name="CurrentPlaylistFileNameTextBlock"
                           Style="{StaticResource Text.PlaylistFileName}"
                           TextTrimming="CharacterEllipsis"
                           MaxWidth="520"
                           Visibility="Collapsed"/>
            </StackPanel>
            <TextBlock Margin="0,4,0,0"
                       Style="{StaticResource Text.Subtitle}"
                       Text="Build XnView MP .sld playlists from multiple folders — add, scan, save."/>
        </StackPanel>

        <!-- Toolbar -->
        <Border Grid.Row="1"
                Style="{StaticResource Panel.Toolbar}"
                Margin="0,0,0,16">
            <DockPanel LastChildFill="False">
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                    <Button x:Name="NewPlaylistButton"
                            Content="New"
                            Style="{StaticResource Button.Secondary}"
                            MinWidth="72"
                            Margin="0,0,8,0"
                            Click="NewPlaylistButton_Click"/>
                    <Button x:Name="OpenPlaylistButton"
                            Content="Open .sld…"
                            Style="{StaticResource Button.Secondary}"
                            MinWidth="104"
                            Margin="0,0,8,0"
                            Click="OpenPlaylistButton_Click"/>
                    <Button x:Name="AddFolderButton"
                            Content="Add folders…"
                            Style="{StaticResource Button.Secondary}"
                            MinWidth="124"
                            Margin="0,0,8,0"
                            ToolTip="Add folders to the scan list (checks folder names only — scan and Check files verify files)"
                            Click="AddFolderButton_Click"/>
                    <Button x:Name="AddFilesButton"
                            Content="Add files…"
                            Style="{StaticResource Button.Secondary}"
                            MinWidth="104"
                            Margin="0,0,8,0"
                            Click="AddFilesButton_Click"/>
                    <Button x:Name="RemoveFolderButton"
                            Content="Remove"
                            Style="{StaticResource Button.Secondary}"
                            MinWidth="92"
                            Click="RemoveFolderButton_Click"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button x:Name="SettingsButton"
                            Content="Settings…"
                            Style="{StaticResource Button.Secondary}"
                            MinWidth="96"
                            Margin="0,0,10,0"
                            Click="SettingsButton_Click"/>
                    <Button x:Name="PlayButton"
                            Content="Play in XnView"
                            Style="{StaticResource Button.Secondary}"
                            MinWidth="128"
                            Margin="0,0,10,0"
                            Click="PlayButton_Click"/>
                    <Button x:Name="SaveAsButton"
                            Content="Save As…"
                            Style="{StaticResource Button.Secondary}"
                            MinWidth="104"
                            Margin="0,0,10,0"
                            Click="SaveAsButton_Click"/>
                    <Button x:Name="SaveButton"
                            Content="Save .sld"
                            Style="{StaticResource Button.Primary}"
                            MinWidth="104"
                            Click="SaveButton_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Main content -->
        <Grid Grid.Row="2" Background="Transparent">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="320"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="400"/>
            </Grid.ColumnDefinitions>

            <!-- Playlist + folders -->
            <Border Grid.Column="0" Style="{StaticResource Panel.Card}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*" MinHeight="120"/>
                        <RowDefinition Height="6"/>
                        <RowDefinition Height="200" MinHeight="120"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,12">
                        <DockPanel Margin="0,0,0,8">
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="0,0,6,0">
                                <Button x:Name="ScanButton"
                                        Content="Scan folders"
                                        Style="{StaticResource Button.Accent}"
                                        MinWidth="104"
                                        Padding="8,4"
                                        FontSize="11"
                                        Margin="8,0,0,0"
                                        Click="ScanButton_Click"/>
                                <Button x:Name="CheckFilesButton"
                                        Content="Check files"
                                        Style="{StaticResource Button.Secondary}"
                                        MinWidth="88"
                                        Padding="8,4"
                                        FontSize="11"
                                        Margin="8,0,0,0"
                                        Click="CheckFilesButton_Click"/>
                                <Button x:Name="FixAsciiPathsButton"
                                        Content="Fix names"
                                        Style="{StaticResource Button.Secondary}"
                                        MinWidth="80"
                                        Padding="8,4"
                                        FontSize="11"
                                        Margin="8,0,0,0"
                                        Click="FixAsciiPathsButton_Click"/>
                                <Button x:Name="SortEntriesButton"
                                        Content="Sort A–Z"
                                        Style="{StaticResource Button.Secondary}"
                                        MinWidth="80"
                                        Padding="8,4"
                                        FontSize="11"
                                        Margin="8,0,0,0"
                                        Click="SortEntriesButton_Click"/>
                                <Button x:Name="MoveEntryDownButton"
                                        Content="Down"
                                        Style="{StaticResource Button.Secondary}"
                                        MinWidth="56"
                                        Padding="8,4"
                                        FontSize="11"
                                        Margin="8,0,0,0"
                                        Click="MoveEntryDownButton_Click"/>
                                <Button x:Name="MoveEntryUpButton"
                                        Content="Up"
                                        Style="{StaticResource Button.Secondary}"
                                        MinWidth="48"
                                        Padding="8,4"
                                        FontSize="11"
                                        Margin="8,0,0,0"
                                        Click="MoveEntryUpButton_Click"/>
                            </StackPanel>
                            <TextBlock x:Name="EntrySectionTitleTextBlock"
                                       Text="Playlist entries"
                                       Style="{StaticResource Text.SectionTitle}"
                                       VerticalAlignment="Center"/>
                        </DockPanel>
                        <TextBox x:Name="EntryFilterTextBox"
                                 Margin="0,0,0,8"
                                 ToolTip="Filter entries by path (live search)"
                                 TextChanged="EntryFilterTextBox_TextChanged"/>
                        <TextBlock Style="{StaticResource Text.Subtitle}"
                                   Text="Select an entry and click Remove, or use Up/Down to reorder."/>
                    </StackPanel>

                    <ListBox x:Name="EntryListBox"
                             Grid.Row="1"
                             DisplayMemberPath="DisplayPath"
                             VirtualizingPanel.IsVirtualizing="True"
                             VirtualizingPanel.ScrollUnit="Pixel"
                             ScrollViewer.CanContentScroll="True"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>

                    <GridSplitter Grid.Row="2"
                                  Height="6"
                                  VerticalAlignment="Stretch"
                                  ResizeDirection="Rows"/>

                    <Grid Grid.Row="3">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="0,8,0,8">
                            <DockPanel Margin="0,0,0,4">
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="0,0,6,0">
                                    <Button x:Name="SortFoldersButton"
                                            Content="Sort A–Z"
                                            Style="{StaticResource Button.Secondary}"
                                            MinWidth="80"
                                            Padding="8,4"
                                            FontSize="11"
                                            Margin="8,0,0,0"
                                            ToolTip="Sort scan folders alphabetically by path"
                                            Click="SortFoldersButton_Click"/>
                                    <Button x:Name="RemoveFolderEntriesButton"
                                            Content="Remove entries"
                                            Style="{StaticResource Button.Secondary}"
                                            MinWidth="112"
                                            Padding="8,4"
                                            FontSize="11"
                                            Margin="8,0,0,0"
                                            IsEnabled="False"
                                            ToolTip="Remove playlist entries under the selected folder (optional: also remove folder from scan list)"
                                            Click="RemoveFolderEntriesButton_Click"/>
                                    <Button x:Name="ToggleAllSubfoldersButton"
                                            Content="Check all"
                                            Style="{StaticResource Button.Secondary}"
                                            MinWidth="96"
                                            Padding="8,4"
                                            FontSize="11"
                                            Margin="8,0,0,0"
                                            IsEnabled="False"
                                            ToolTip="Check or uncheck Include subfolders for every folder in the list"
                                            Click="ToggleAllSubfoldersButton_Click"/>
                                </StackPanel>
                                <TextBlock Text="Folders to scan"
                                           Style="{StaticResource Text.SectionTitle}"
                                           VerticalAlignment="Center"/>
                            </DockPanel>
                            <TextBlock Style="{StaticResource Text.Subtitle}"
                                       Text="Click a folder path to select it. Ctrl+click or Shift+click for multiple. Use the checkbox squares only to toggle options."/>
                        </StackPanel>

                        <ListBox x:Name="FolderListBox"
                                 Grid.Row="1"
                                 SelectionMode="Extended"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 PreviewMouseLeftButtonDown="FolderListBox_PreviewMouseLeftButtonDown">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock Text="{Binding AbsolutePath}"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding AbsolutePath}"
                                                   Margin="0,0,0,8"
                                                   Cursor="Hand"/>
                                        <Button Content="{Binding CollapsedSubfoldersLabel}"
                                                Padding="0"
                                                Margin="0,0,0,8"
                                                HorizontalAlignment="Left"
                                                FontSize="11"
                                                Click="CollapsedSubfoldersButton_Click">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource Button.Ghost}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasCollapsedSubfolders}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        <ItemsControl ItemsSource="{Binding CollapsedSubfolderPaths}"
                                                      Margin="12,0,0,8">
                                            <ItemsControl.Style>
                                                <Style TargetType="ItemsControl">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ShowCollapsedSubfolders}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ItemsControl.Style>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding}"
                                                               TextTrimming="CharacterEllipsis"
                                                               ToolTip="{Binding}"
                                                               FontFamily="{StaticResource Font.Mono}"
                                                               FontSize="11"
                                                               Foreground="{StaticResource Brush.TextSecondary}"
                                                               Margin="0,0,0,4"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                            <CheckBox IsChecked="{Binding IncludeSubfolders, Mode=TwoWay}"
                                                      Focusable="False"
                                                      VerticalAlignment="Center"
                                                      Width="16"
                                                      Height="16"
                                                      Padding="0"
                                                      Margin="0"/>
                                            <TextBlock Text="Include subfolders"
                                                       VerticalAlignment="Center"
                                                       Margin="8,0,0,0"
                                                       Foreground="{StaticResource Brush.TextSecondary}"
                                                       IsHitTestVisible="False"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <CheckBox IsChecked="{Binding UseWildcardLine, Mode=TwoWay}"
                                                      Focusable="False"
                                                      VerticalAlignment="Center"
                                                      Width="16"
                                                      Height="16"
                                                      Padding="0"
                                                      Margin="0"
                                                      ToolTip="Write one folder wildcard line instead of scanning individual files"/>
                                            <TextBlock Text="Wildcard line (*.*)"
                                                       VerticalAlignment="Center"
                                                       Margin="8,0,0,0"
                                                       Foreground="{StaticResource Brush.TextSecondary}"
                                                       IsHitTestVisible="False"/>
                                        </StackPanel>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Grid>
            </Border>

            <!-- Slideshow options (fixed width) -->
            <Border Grid.Column="2"
                    Style="{StaticResource Panel.Card}"
                    HorizontalAlignment="Left"
                    Width="400">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="Slideshow options"
                               Style="{StaticResource Text.SectionTitle}"/>

                    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="Transparent">
                        <StackPanel Background="Transparent">
                            <TextBlock Text="Presets" Style="{StaticResource Text.GroupTitle}"/>
                            <DockPanel Margin="0,0,0,16" LastChildFill="True">
                                <StackPanel DockPanel.Dock="Right"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center"
                                            Margin="0,0,6,0">
                                    <Button x:Name="LoadPresetButton"
                                            Content="Load"
                                            Style="{StaticResource Button.Secondary}"
                                            MinWidth="72"
                                            Margin="8,0,0,0"
                                            Click="LoadPresetButton_Click"/>
                                    <Button x:Name="DeletePresetButton"
                                            Content="Delete"
                                            Style="{StaticResource Button.Secondary}"
                                            MinWidth="72"
                                            Margin="8,0,0,0"
                                            Click="DeletePresetButton_Click"/>
                                    <Button x:Name="SavePresetButton"
                                            Content="Save as…"
                                            Style="{StaticResource Button.Secondary}"
                                            MinWidth="88"
                                            Margin="8,0,0,0"
                                            Click="SavePresetButton_Click"/>
                                </StackPanel>
                                <ComboBox x:Name="PresetComboBox"
                                          Style="{StaticResource ComboBox.Compact}"
                                          VerticalAlignment="Center"
                                          MinWidth="180"
                                          IsEditable="False"/>
                            </DockPanel>

                            <TextBlock Text="Playback" Style="{StaticResource Text.GroupTitle}"/>
                            <UniformGrid Columns="2" Margin="0,0,0,16">
                                <CheckBox x:Name="UseTimerCheckBox" Content="Use timer" IsChecked="True"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="Timer (sec)" Style="{StaticResource Text.Label}" Width="96"/>
                                    <TextBox x:Name="TimerTextBox" Width="72" Text="15"/>
                                </StackPanel>
                                <CheckBox x:Name="LoopCheckBox" Content="Loop" IsChecked="True"/>
                                <CheckBox x:Name="FullScreenCheckBox" Content="Full screen" IsChecked="True"/>
                                <CheckBox x:Name="StretchCheckBox" Content="Stretch" IsChecked="True"/>
                                <CheckBox x:Name="RandomOrderCheckBox" Content="Random order" IsChecked="True"/>
                            </UniformGrid>

                            <TextBlock Text="Window" Style="{StaticResource Text.GroupTitle}"/>
                            <UniformGrid Columns="2" Margin="0,0,0,16">
                                <CheckBox x:Name="ShowInfoCheckBox" Content="Show info" IsChecked="True"/>
                                <CheckBox x:Name="TitleBarCheckBox" Content="Title bar"/>
                                <CheckBox x:Name="OnTopCheckBox" Content="On top"/>
                                <CheckBox x:Name="CursorAutoHideCheckBox" Content="Cursor auto-hide"/>
                            </UniformGrid>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <TextBlock Text="Win size" Style="{StaticResource Text.Label}" Width="96"/>
                                <TextBox x:Name="WinWidthTextBox" Width="72" Text="640" Margin="0,0,8,0"/>
                                <TextBox x:Name="WinHeightTextBox" Width="72" Text="480"/>
                            </StackPanel>

                            <StackPanel Margin="0,0,0,12">
                                <TextBlock x:Name="InfoTemplateLabelTextBlock"
                                           Style="{StaticResource Text.Label}">
                                    <Run Text="Info template"/>
                                    <Run Text=" ⓘ" Foreground="{StaticResource Brush.TextMuted}"/>
                                </TextBlock>
                                <DockPanel Margin="0,6,0,0">
                                    <Button x:Name="InsertInfoTokenButton"
                                            Content="Insert"
                                            Style="{StaticResource Button.Secondary}"
                                            DockPanel.Dock="Right"
                                            MinWidth="72"
                                            Margin="8,0,0,0"
                                            Click="InsertInfoTokenButton_Click"/>
                                    <TextBox x:Name="InfoTextBox"/>
                                </DockPanel>
                            </StackPanel>

                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Style="{StaticResource Text.Label}">
                                    <Run Text="Font"/>
                                    <Run Text=" ⓘ" Foreground="{StaticResource Brush.TextMuted}"/>
                                </TextBlock>
                                <DockPanel Margin="0,6,0,0">
                                    <Button x:Name="ChooseFontButton"
                                            Content="Choose…"
                                            Style="{StaticResource Button.Secondary}"
                                            DockPanel.Dock="Right"
                                            MinWidth="88"
                                            Margin="8,0,0,0"
                                            Click="ChooseFontButton_Click"/>
                                    <TextBox x:Name="FontTextBox"
                                             Text="MS Shell Dlg 2,8.25,-1,5,50,0,0,0,0,0"/>
                                </DockPanel>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <TextBlock Text="Effect ms" Style="{StaticResource Text.Label}" Width="96"/>
                                <TextBox x:Name="EffectDurationTextBox" Width="72" Text="1000"/>
                                <TextBlock Text="Opacity" Style="{StaticResource Text.Label}" Width="72" Margin="16,0,0,0"/>
                                <TextBox x:Name="OpacityTextBox" Width="72" Text="100"/>
                            </StackPanel>

                            <TextBlock Text="Appearance" Style="{StaticResource Text.GroupTitle}"/>
                            <controls:RgbaColorEditor x:Name="BackgroundColorEditor"
                                                      Label="Background"
                                                      Margin="0,0,0,8"/>
                            <controls:RgbaColorEditor x:Name="TextColorEditor"
                                                      Label="Text color"
                                                      Margin="0,0,0,8"/>
                            <CheckBox x:Name="UseTextBackColorCheckBox"
                                      Content="Text background color"
                                      Margin="0,0,0,8"
                                      Checked="UseTextBackColorCheckBox_Changed"
                                      Unchecked="UseTextBackColorCheckBox_Changed"/>
                            <controls:RgbaColorEditor x:Name="TextBackColorEditor"
                                                      Label="Text back"
                                                      Margin="0,0,0,8"
                                                      IsEnabled="False"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <TextBlock Text="Text position" Style="{StaticResource Text.Label}" Width="96"/>
                                <ComboBox x:Name="TextPositionComboBox"
                                          MinWidth="200"
                                          DisplayMemberPath="Label"
                                          SelectedValuePath="Value"
                                          ToolTip="XnView MP overlay position: 0=top left, 1=top center, 2=top right, 3=left center, … 8=bottom right."/>
                            </StackPanel>

                            <Expander Header="Transition effects"
                                      Foreground="{StaticResource Brush.TextSecondary}"
                                      IsExpanded="False"
                                      Margin="0,0,0,8">
                                <StackPanel Margin="0,8,0,0">
                                    <CheckBox x:Name="AllEffectsCheckBox"
                                              Content="Use all 56 effects"
                                              Margin="0,0,0,8"/>
                                    <ScrollViewer MaxHeight="160" VerticalScrollBarVisibility="Auto">
                                        <ItemsControl x:Name="EffectsItemsControl"/>
                                    </ScrollViewer>
                                </StackPanel>
                            </Expander>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>

        <!-- Status -->
        <Border Grid.Row="3"
                Style="{StaticResource Panel.Footer}"
                Margin="0,16,0,8">
            <TextBlock x:Name="StatusTextBlock"
                       TextWrapping="Wrap"
                       Foreground="{StaticResource Brush.TextPrimary}"
                       FontSize="13"
                       Text="Add folders, scan, then save a .sld playlist."/>
        </Border>

        <!-- Footer -->
        <Border Grid.Row="4" Style="{StaticResource Panel.Footer}">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                    <Button x:Name="UndoRenamesButton"
                            Content="Undo renames"
                            Style="{StaticResource Button.Secondary}"
                            Margin="0,0,8,0"
                            Click="UndoRenamesButton_Click"/>
                    <Button x:Name="OpenLogButton"
                            Content="Open log folder"
                            Style="{StaticResource Button.Secondary}"
                            Click="OpenLogButton_Click"/>
                </StackPanel>
                <TextBlock x:Name="LogPathTextBlock"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource Brush.TextSecondary}"
                           FontFamily="{StaticResource Font.Mono}"
                           FontSize="11"
                           TextTrimming="CharacterEllipsis"
                           ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
