<Window x:Class="XnViewPlaylistBuilder.PresetNameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Save preset"
        Height="260"
        Width="440"
        MinHeight="240"
        MinWidth="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource Brush.Background}"
        Foreground="{StaticResource Brush.TextPrimary}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Preset name"
                   Style="{StaticResource Text.SectionTitle}"/>
        <TextBox x:Name="PresetNameTextBox"
                 Grid.Row="1"
                 Margin="0,12,0,0"/>
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,20,0,0">
            <Button Content="Cancel"
                    Style="{StaticResource Button.Secondary}"
                    MinWidth="88"
                    Margin="0,0,8,0"
                    IsCancel="True"/>
            <Button Content="Save"
                    Style="{StaticResource Button.Primary}"
                    MinWidth="88"
                    IsDefault="True"
                    Click="SaveButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
