<Window x:Class="XnViewPlaylistBuilder.SaveSummaryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Confirm save"
        Height="520"
        Width="560"
        MinHeight="420"
        MinWidth="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="{StaticResource Brush.Background}"
        Foreground="{StaticResource Brush.TextPrimary}">
    <Grid Margin="24" Background="{StaticResource Brush.Background}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Save playlist" Style="{StaticResource Text.Display}"/>
            <TextBlock Margin="0,4,0,0"
                       Style="{StaticResource Text.Subtitle}"
                       Text="Review the summary below before writing the .sld file."/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Style="{StaticResource Panel.Card}" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Summary" Style="{StaticResource Text.GroupTitle}"/>
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="128"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Output file" Style="{StaticResource Text.Label}"/>
                            <TextBlock x:Name="OutputPathTextBlock"
                                       Grid.Row="0"
                                       Grid.Column="1"
                                       TextWrapping="Wrap"
                                       FontFamily="{StaticResource Font.Mono}"
                                       FontSize="11"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Entries" Style="{StaticResource Text.Label}" Margin="0,8,0,0"/>
                            <TextBlock x:Name="EntryCountTextBlock" Grid.Row="1" Grid.Column="1" Margin="0,8,0,0"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Path policy" Style="{StaticResource Text.Label}" Margin="0,8,0,0"/>
                            <TextBlock x:Name="PathPolicyTextBlock" Grid.Row="2" Grid.Column="1" Margin="0,8,0,0" TextWrapping="Wrap"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Missing files" Style="{StaticResource Text.Label}" Margin="0,8,0,0"/>
                            <TextBlock x:Name="MissingCountTextBlock" Grid.Row="3" Grid.Column="1" Margin="0,8,0,0" TextWrapping="Wrap"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Unplayable files" Style="{StaticResource Text.Label}" Margin="0,8,0,0"/>
                            <TextBlock x:Name="UnplayableCountTextBlock" Grid.Row="4" Grid.Column="1" Margin="0,8,0,0" TextWrapping="Wrap"/>
                        </Grid>

                        <TextBlock x:Name="UnicodePathWarningTextBlock"
                                   Margin="0,16,0,0"
                                   Foreground="{StaticResource Brush.Accent}"
                                   TextWrapping="Wrap"
                                   Visibility="Collapsed"/>

                        <TextBlock x:Name="UnplayableFileWarningTextBlock"
                                   Margin="0,16,0,0"
                                   Foreground="{StaticResource Brush.Accent}"
                                   TextWrapping="Wrap"
                                   Visibility="Collapsed"/>

                        <TextBlock x:Name="ExperimentalWarningTextBlock"
                                   Margin="0,16,0,0"
                                   Foreground="{StaticResource Brush.Accent}"
                                   TextWrapping="Wrap"
                                   Visibility="Collapsed"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Panel.Card}">
                    <StackPanel>
                        <TextBlock Text="Slideshow options" Style="{StaticResource Text.GroupTitle}"/>
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="128"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Playback" Style="{StaticResource Text.Label}"/>
                            <TextBlock x:Name="PlaybackSummaryTextBlock"
                                       Grid.Row="0"
                                       Grid.Column="1"
                                       TextWrapping="Wrap"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Overlay" Style="{StaticResource Text.Label}" Margin="0,8,0,0"/>
                            <TextBlock x:Name="OverlaySummaryTextBlock"
                                       Grid.Row="1"
                                       Grid.Column="1"
                                       Margin="0,8,0,0"
                                       TextWrapping="Wrap"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Effects" Style="{StaticResource Text.Label}" Margin="0,8,0,0"/>
                            <TextBlock x:Name="EffectsSummaryTextBlock"
                                       Grid.Row="2"
                                       Grid.Column="1"
                                       Margin="0,8,0,0"
                                       TextWrapping="Wrap"/>

                            <TextBlock x:Name="WindowSummaryLabelTextBlock"
                                       Grid.Row="3"
                                       Grid.Column="0"
                                       Text="Window"
                                       Style="{StaticResource Text.Label}"
                                       Margin="0,8,0,0"/>
                            <TextBlock x:Name="WindowSummaryTextBlock"
                                       Grid.Row="3"
                                       Grid.Column="1"
                                       Margin="0,8,0,0"
                                       TextWrapping="Wrap"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button Content="Cancel"
                    Style="{StaticResource Button.Secondary}"
                    MinWidth="88"
                    Margin="0,0,8,0"
                    IsCancel="True"/>
            <Button Content="Save"
                    Style="{StaticResource Button.Primary}"
                    MinWidth="88"
                    IsDefault="True"
                    Click="SaveButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
